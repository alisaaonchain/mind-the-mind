# ---------------------------------------------------------------------------
# Live LLM agent (optional)
# ---------------------------------------------------------------------------
# Without these, the game runs fully on the deterministic scripted agents.
# Set a key to have an OpenRouter model role-play the agent during the
# interrogation and the reveal debrief. The key stays server-side (used only
# in the /api/agent route handler).

# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any OpenRouter model id. Defaults to a free model if unset.
# Browse current free models: https://openrouter.ai/models?q=free
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
