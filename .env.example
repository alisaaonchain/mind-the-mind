# ---------------------------------------------------------------------------
# Live LLM agent (optional)
# ---------------------------------------------------------------------------
# Without these, the game runs fully on the deterministic scripted agents.
# Set a key to have an OpenRouter model role-play the agent during the
# interrogation and the reveal debrief. The key stays server-side (used only
# in the /api/agent route handler).

# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any OpenRouter model id. Defaults to a free model if unset.
# Browse current free models: https://openrouter.ai/models?q=free
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free


# ---------------------------------------------------------------------------
# Cosmos seed (optional)
# ---------------------------------------------------------------------------
# Read-only public Cosmos REST/LCD endpoint used to seed each round from live
# chain state. Defaults to a public Cosmos Hub endpoint. No key required.
# Falls back to a local seed if the endpoint is unreachable.
COSMOS_LCD=https://rest.cosmos.directory/cosmoshub


# ---------------------------------------------------------------------------
# On-chain settlement (optional) — Cosmos EVM
# ---------------------------------------------------------------------------
# When set, each finished round is recorded on-chain by a backend signer
# (no player wallet needed). Unset = settlement is simply skipped.
# Deploy contracts/RoundLog.sol once (see contracts/README.md), fund the signer
# from a testnet faucet, then set:

# JSON-RPC URL of the Cosmos EVM (testnet) chain
COSMOS_EVM_RPC=
# Private key of the deployer/owner of RoundLog (the backend signer). Keep secret.
SETTLE_PRIVATE_KEY=
# Deployed RoundLog contract address
ROUNDLOG_ADDRESS=
# Block explorer tx base URL, e.g. https://explorer.example/tx  (hash is appended)
EXPLORER_TX_URL=
